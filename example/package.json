{
  "name": "react-native-nitro-image-pipeline-example",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios --simulator='iPhone 16'",
    "lint": "biome check .",
    "pod": "bundle install && bundle exec pod install --project-directory=ios",
    "start": "react-native start --reset-cache",
    "test": "jest",
    "test:harness:ios": "react-native-harness --harnessRunner iphone-17",
    "test:harness:android": "react-native-harness --harnessRunner medium_phone_api_36.1"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.84.1",
    "react": "19.2.5",
    "react-native": "0.84.1",
    "react-native-harness": "^1.1.0",
    "react-native-nitro-image": "0.13.1",
    "react-native-nitro-modules": "0.35.4",
    "react-native-safe-area-context": "^5.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native-harness/platform-android": "^1.1.0",
    "@react-native-harness/platform-apple": "^1.1.0",
    "@react-native-harness/ui": "^1.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^30.0.0",
    "babel-plugin-module-resolver": "^5.0.2"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
