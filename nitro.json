{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["nitroimagepipeline"],
  "ios": {
    "iosModuleName": "NitroImagePipeline"
  },
  "android": {
    "androidNamespace": ["nitroimagepipeline"],
    "androidCxxLibName": "NitroImagePipeline"
  },
  "autolinking": {
    "NitroImagePipeline": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridNitroImagePipeline"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridNitroImagePipeline"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
